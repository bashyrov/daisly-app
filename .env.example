# Daisly production environment template.
# Copy this file to `.env` locally or add the same keys to your hosting provider.
# Never commit real secrets.

NODE_ENV=production
PORT=4173

# Public URLs
PUBLIC_APP_URL=https://daisly.space
PUBLIC_SITE_URL=https://daisly.space
PUBLIC_API_URL=https://api.daisly.space
PRIVACY_POLICY_URL=https://daisly.space/privacy
TERMS_OF_SERVICE_URL=https://daisly.space/terms
SUPPORT_EMAIL=support@daisly.space
CORS_ORIGIN=https://daisly.space,https://www.daisly.space,null

# Storage
# Use `json` for local prototype mode, `supabase` for deployed backend mode.
STORAGE_MODE=supabase
DAISLY_STATE_KEY=production
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DIRECT_URL=

# Google OAuth / sync
GOOGLE_IOS_CLIENT_ID=
GOOGLE_IOS_URL_SCHEME=
GOOGLE_WEB_CLIENT_ID=
GOOGLE_WEB_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.daisly.space/auth/google/callback

# Apple
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=com.daisly.app
APPLE_SERVICES_ID=com.daisly.app.web
APPLE_SIGNIN_KEY_ID=
APPLE_SIGNIN_PRIVATE_KEY_PATH=
APPLE_APNS_KEY_ID=
APPLE_APNS_PRIVATE_KEY_PATH=

# App Store Connect
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_PRIVATE_KEY_PATH=
APPLE_APP_ID=
APP_STORE_SKU=daisly-ios

# Payments
REVENUECAT_PUBLIC_SDK_KEY=
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT_ID=
PRODUCT_ID_MONTHLY=daisly_pro_monthly
PRODUCT_ID_YEARLY=daisly_pro_yearly

# Optional analytics / errors
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
POSTHOG_API_KEY=
POSTHOG_HOST=
